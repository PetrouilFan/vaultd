{
  "name": "vaultd",
  "version": "1.0.0",
  "description": "Real-time bidirectional sync for Obsidian vaults using CRDT",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --outfile=main.js --external:obsidian --external:electron",
    "dev": "esbuild src/main.ts --bundle --platform=node --outfile=main.js --external:obsidian --external:electron --watch"
  },
  "keywords": ["obsidian", "sync", "crdt", "yjs"],
  "author": "Vaultd",
  "license": "MIT",
  "dependencies": {
    "yjs": "^13.6",
    "y-codemirror.next": "^0.3",
    "diff-match-patch": "^1.0"
  },
  "devDependencies": {
    "obsidian": "latest",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.19.0",
    "@types/diff-match-patch": "^1.0.36"
  }
}